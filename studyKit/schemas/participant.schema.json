{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sound Maze Participant Schema",
  "type": "object",
  "required": [
    "participant_id",
    "study_id",
    "consent"
  ],
  "properties": {
    "participant_id": {
      "type": "string"
    },
    "study_id": {
      "type": "string"
    },
    "preferred_input_mode": {
      "type": "string"
    },
    "preferred_audio_mode": {
      "type": "string"
    },
    "consent": {
      "type": "object"
    }
  }
}